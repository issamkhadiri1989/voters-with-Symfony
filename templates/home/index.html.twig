{% extends 'base.html.twig' %}
{% block body %}
    <section class="py-5 bg-body-secondary border-bottom">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-7">
                    <span class="badge text-bg-primary mb-3 fw-normal px-3 py-2 rounded-pill">The Journal</span>
                    <h1 class="display-4 fw-bold mb-3">Stories, ideas &amp; insights</h1>
                    <p class="lead text-body-secondary mb-0">Curated articles on design, technology, and the craft of building products people love.</p>
                </div>
                <div class="col-lg-5 mt-4 mt-lg-0 d-flex justify-content-lg-end">
                    <div class="input-group" style="max-width: 360px;">
                        <input type="text" class="form-control" placeholder="Search articles…" aria-label="Search articles">
                        <button class="btn btn-primary px-4" type="button">Search</button>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <section class="py-5 border-bottom">
        <div class="container">
            <p class="text-uppercase text-body-tertiary fw-semibold small letter-spacing-1 mb-4">Featured</p>
            <div class="row g-4 align-items-center">
                <div class="col-lg-6">
                    <a href="" class="text-decoration-none d-block overflow-hidden rounded-4">
                        <img
                            src="https://placehold.co/800x480/1a1a2e/ffffff?text=Featured+Post"
                            alt="Featured post thumbnail"
                            class="img-fluid w-100 object-fit-cover"
                            style="max-height: 380px;"
                        >
                    </a>
                </div>
                <div class="col-lg-6">
                    <div class="ps-lg-4">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <span class="badge text-bg-warning">Design</span>
                            <span class="text-body-tertiary small">·</span>
                            <span class="text-body-tertiary small">12 min read</span>
                        </div>
                        <h2 class="display-6 fw-bold mb-3">
                            <a href="#" class="text-decoration-none text-body">The quiet revolution of white space in modern UI design</a>
                        </h2>
                        <p class="text-body-secondary mb-4">Negative space isn't emptiness — it's a deliberate tool that shapes perception, guides attention, and gives interfaces room to breathe. We explore why leading designers are saying less to communicate more.</p>
                        <div class="d-flex align-items-center gap-3">
                            <img src="https://placehold.co/44x44/6f42c1/ffffff?text=AR" alt="Author avatar" class="rounded-circle" width="44" height="44">
                            <div>
                                <p class="fw-semibold mb-0 small">Amara Reyes</p>
                                <p class="text-body-tertiary mb-0 small">June 4, 2025</p>
                            </div>
                            <a href="" class="ms-auto btn btn-outline-primary btn-sm px-4 rounded-pill">Read more →</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <section class="py-4 border-bottom bg-body-tertiary sticky-top" style="z-index: 100;">
        <div class="container">
            <div class="d-flex flex-wrap gap-2 align-items-center">
                <span class="text-body-secondary small me-2 d-none d-sm-inline">Filter:</span>
                <a href="#" class="btn btn-primary btn-sm rounded-pill px-3">All</a>
                <a href="#" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Design</a>
                <a href="#" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Engineering</a>
                <a href="#" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Product</a>
                <a href="#" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Culture</a>
                <a href="#" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Tools</a>
            </div>
        </div>
    </section>

    <section class="py-5">
        <div class="container">
            <div class="row g-4">
                {% for item in blogs %}
                <div class="col-sm-6 col-lg-4">
                    <article class="card h-100 border shadow-sm rounded-4 overflow-hidden">
                        <a href="{{ url('app_blog__show', {id: item.id}) }}" class="d-block overflow-hidden" style="max-height: 200px;">
                            <img src="https://placehold.co/600x360/0d6efd/ffffff?text={{ item.category.name }}"
                                 class="card-img-top object-fit-cover w-100 h-100"
                                 alt="{{ item.title }}"
                            />
                        </a>
                        <div class="card-body d-flex flex-column p-4">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <span class="badge text-bg-primary fw-normal">{{ item.category.name }}</span>
                                <span class="text-body-tertiary small">8 min read</span>
                            </div>
                            <h3 class="card-title h5 fw-bold mb-2">
                                <a href="{{ url('app_blog__show', {id: item.id}) }}" class="text-decoration-none text-body">
                                    {{ item.title }}
                                </a>
                            </h3>
                            <div class="d-flex align-items-center justify-content-between mt-auto">
                                <div class="d-flex align-items-center gap-2">
                                    <img src="https://placehold.co/32x32/198754/ffffff?text=KL"
                                         alt="Author"
                                         class="rounded-circle"
                                         width="32"
                                         height="32"
                                    />
                                    <div>
                                        <p class="mb-0 small fw-semibold">
                                            {{ item.author.fullName }}
                                        </p>
                                        <p class="mb-0 text-body-tertiary" style="font-size: 0.75rem;">
                                            {{ item.createdAt | date('F, d Y') }}
                                        </p>
                                    </div>
                                </div>
                                <a href="{{ url('app_blog__show', {id: item.id}) }}"
                                   class="text-primary text-decoration-none small fw-semibold">
                                    Read →
                                </a>
                            </div>
                        </div>
                    </article>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>
    <section class="pb-5">
        <div class="container">
            <nav aria-label="Blog pagination">
                <ul class="pagination justify-content-center gap-1">
                    <li class="page-item disabled">
                        <a class="page-link rounded-3 border" href="#" tabindex="-1" aria-disabled="true">← Prev</a>
                    </li>
                    <li class="page-item active" aria-current="page">
                        <a class="page-link rounded-3 border" href="#">1</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link rounded-3 border" href="#">2</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link rounded-3 border" href="#">3</a>
                    </li>
                    <li class="page-item">
                        <span class="page-link border-0 text-body-tertiary">…</span>
                    </li>
                    <li class="page-item">
                        <a class="page-link rounded-3 border" href="#">8</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link rounded-3 border" href="#">Next →</a>
                    </li>
                </ul>
            </nav>
        </div>
    </section>
    <section class="py-5 bg-primary text-white">
        <div class="container text-center">
            <h2 class="fw-bold mb-2">Never miss a story</h2>
            <p class="text-white-50 mb-4">Fresh articles delivered to your inbox every two weeks. No spam, ever.</p>
            <div class="row justify-content-center">
                <div class="col-md-6">
                    <div class="input-group">
                        <input type="email" class="form-control form-control-lg" placeholder="you@example.com" aria-label="Email address">
                        <button class="btn btn-light text-primary fw-semibold px-4" type="button">Subscribe</button>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
