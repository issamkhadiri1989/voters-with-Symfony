{% extends 'base.html.twig' %}
{% block body %}
    {% if last_error %}
        <div class="alert alert-danger">
            <p>{{ last_error.messageKey | trans(last_error.messageData, 'security') }}</p>
        </div>
    {% endif %}
    <div class="mt-2 mb-2">
        <form action="{{ url('app.login') }}" method="post">
            <div class="form-group">
                <label class="form-label" for="username">Email: </label>
                <input required
                       type="text"
                       name="_username"
                       id="username"
                       class="form-control"
                       value="{{ last_username }}"
                />
            </div>
            <div class="form-group">
                <label class="form-label" for="password">Password: </label>
                <input type="password"
                       name="_password"
                       id="password"
                       class="form-control"
                />
            </div>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('login') }}"/>
            <div class="form-group mt-2 mb-2">
                <button class="btn btn-success" type="submit">
                    Sign in
                </button>
            </div>
        </form>
    </div>
{% endblock body %}
